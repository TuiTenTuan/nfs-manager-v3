# Copy to deploy/.env before running: cp deploy/.env.example deploy/.env

# PostgreSQL (postgres service)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=nfsmanager
DATABASE_PASSWORD=change-me
DATABASE_NAME=nfsmanager_v3
DATABASE_SSL_MODE=disable
POSTGRES_USER=nfsmanager
POSTGRES_PASSWORD=change-me
POSTGRES_DB=nfsmanager_v3

# API
APP_ENV=production
API_PORT=8081
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
CORS_ORIGIN=http://localhost:3001

# NFS (linux provider — in-container NFS server)
NFS_PROVIDER=linux
NFS_SERVER_HOST=localhost
NFS_ROOT_ALLOWLIST=/srv,/data,/export,/mnt
MANAGED_EXPORTS_PATH=/etc/exports.d/nfs-manager.exports

# Frontend (baked at image build time; listed here for reference)
NEXT_PUBLIC_API_BASE=http://localhost:8081/api/v3
NEXT_PUBLIC_APP_NAME=NFS Manager v3
APP_PORT=3001
HOSTNAME=0.0.0.0
